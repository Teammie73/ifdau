<header class="topbar">
  <div class="d-flex align-center gap-12">
    <button class="menu-toggle" id="menuToggle" aria-label="Menü">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <h1 class="topbar-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : title %></h1>
  </div>
  <div class="topbar-actions">
    <% if (user && user.role === 'admin') { %>
      <% if (typeof adminView !== 'undefined' && adminView) { %>
        <a href="/dashboard" class="btn btn-sm btn-secondary">Mitarbeiter-Ansicht</a>
      <% } else { %>
        <a href="/admin/dashboard" class="btn btn-sm btn-secondary">Admin-Bereich</a>
      <% } %>
    <% } %>
  </div>
</header>
