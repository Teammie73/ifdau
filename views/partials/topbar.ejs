<header class="topbar">
  <div class="d-flex align-center gap-12">
    <button class="menu-toggle" id="menuToggle" aria-label="Menü">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <h1 class="topbar-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : title %></h1>
  </div>
  <div class="topbar-actions">
    <% if (user && user.role === 'admin') { %>
      <% if (typeof adminView !== 'undefined' && adminView) { %>
        <a href="/dashboard" class="btn btn-sm btn-secondary">Mitarbeiter-Ansicht</a>
      <% } else { %>
        <a href="/admin/dashboard" class="btn btn-sm btn-secondary">Admin-Bereich</a>
      <% } %>
    <% } %>
    <a href="/logout" class="btn btn-sm btn-secondary" style="display:flex;align-items:center;gap:6px;">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:15px;height:15px;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Abmelden
    </a>
  </div>
</header>
