<!DOCTYPE html>
<html lang="de">
<head>
  <%- include('../partials/head') %>
  <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
</head>
<body>
<div class="app-layout">
  <%- include('../partials/admin-sidebar', { activePage: 'trainings' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: training ? 'Unterweisung bearbeiten' : 'Neue Unterweisung', adminView: true }) %>
    <div class="page-content">

      <div style="max-width:900px;margin:0 auto;">
        <div class="d-flex align-center gap-12 mb-24">
          <a href="/admin/trainings" class="btn btn-sm btn-secondary">← Zurück</a>
          <h2 style="font-size:18px;font-weight:600;"><%= training ? 'Unterweisung bearbeiten' : 'Neue Unterweisung erstellen' %></h2>
        </div>

        <form method="POST" action="<%= training ? '/admin/trainings/'+training.id : '/admin/trainings' %>">
          <% if (training) { %><input type="hidden" name="_method" value="PUT"><% } %>
          <input type="hidden" name="content" id="contentHidden" value="<%= training ? training.content : '' %>">
          <input type="hidden" name="questionsJson" id="questionsJson">

          <!-- Basic Info -->
          <div class="card" style="margin-bottom:20px;">
            <div class="card-header"><span class="card-title">Grunddaten</span></div>
            <div class="card-body">
              <div class="form-group">
                <label class="form-label">Titel <span class="required">*</span></label>
                <input type="text" name="title" class="form-control" required
                       value="<%= training ? training.title : '' %>"
                       placeholder="z.B. Allgemeine Arbeitsschutzunterweisung">
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Kategorie</label>
                  <select name="category_id" class="form-control">
                    <option value="">Keine Kategorie</option>
                    <% categories.forEach(c => { %>
                      <option value="<%= c.id %>" <%= training && training.category_id == c.id ? 'selected' : '' %>>
                        <%= c.name %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Bestehensgrenze (%)</label>
                  <input type="number" name="passing_score" class="form-control"
                         min="1" max="100" value="<%= training ? training.passing_score : 80 %>">
                </div>
                <div class="form-group">
                  <label class="form-label">Wiederholungsintervall</label>
                  <select name="repeat_interval" class="form-control">
                    <option value="yearly"     <%= !training || training.repeat_interval==='yearly'     ? 'selected' : '' %>>Jährlich</option>
                    <option value="halfyearly" <%= training && training.repeat_interval==='halfyearly' ? 'selected' : '' %>>Halbjährlich</option>
                    <option value="never"      <%= training && training.repeat_interval==='never'      ? 'selected' : '' %>>Einmalig (nie wiederholen)</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="card" style="margin-bottom:20px;">
            <div class="card-header"><span class="card-title">Lerninhalt</span></div>
            <div class="card-body">
              <div id="quillEditor" style="min-height:300px;"></div>
              <p class="form-hint mt-8">Verwenden Sie Überschriften (H2, H3) und Listen für eine klare Struktur.</p>
            </div>
          </div>

          <!-- Questions -->
          <div class="card" style="margin-bottom:20px;">
            <div class="card-header">
              <span class="card-title">Fragen & Lernerfolgskontrolle</span>
              <button type="button" class="btn btn-sm btn-secondary" id="addQuestionBtn">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                Frage hinzufügen
              </button>
            </div>
            <div class="card-body">
              <div id="questionsList"></div>
              <p class="form-hint">Fügen Sie mindestens eine Frage hinzu. Bei Mehrfachauswahl können mehrere Antworten als "Richtig" markiert werden.</p>
            </div>
          </div>

          <div style="display:flex;gap:12px;justify-content:flex-end;">
            <a href="/admin/trainings" class="btn btn-secondary">Abbrechen</a>
            <button type="submit" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <%= training ? 'Änderungen speichern' : 'Unterweisung erstellen' %>
            </button>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script src="/js/main.js"></script>
<script>
// Init Quill
window.initQuill('#quillEditor', 'contentHidden', document.getElementById('contentHidden').value);

// Existing questions for editing
window.EXISTING_QUESTIONS = <%- JSON.stringify(questions) %>;
</script>
</body>
</html>
