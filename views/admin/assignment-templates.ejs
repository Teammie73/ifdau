<!DOCTYPE html>
<html lang="de">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/admin-sidebar', { activePage: 'templates' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Zuweisungsvorlagen', adminView: true }) %>
    <div class="page-content">

      <% if (success) { %><div class="alert alert-success"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><%= success %></div><% } %>
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

      <div class="page-header">
        <div class="page-header-title">
          <h1>Zuweisungsvorlagen</h1>
          <p><%= templates.length %> Vorlage(n)</p>
        </div>
        <div class="page-header-actions">
          <a href="/admin/assignment-templates/new" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Neue Vorlage
          </a>
        </div>
      </div>

      <div class="card">
        <% if (templates.length === 0) { %>
          <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="display:block;"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 7.5V6.108c0-1.135.845-2.098 1.976-2.192.373-.03.748-.057 1.123-.08M15.75 18H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08M15.75 18.75v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5A3.375 3.375 0 006.375 7.5H5.25m11.9-3.664A2.251 2.251 0 0015 2.25h-1.5a2.251 2.251 0 00-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 00-9-9z"/></svg>
            <h3>Keine Vorlagen</h3>
            <p>Erstellen Sie Vorlagen, um beim Zuweisen schnell mehrere Unterweisungen zu wählen.</p>
            <a href="/admin/assignment-templates/new" class="btn btn-primary" style="margin-top:12px;">Erste Vorlage erstellen</a>
          </div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Beschreibung</th>
                <th>Unterweisungen</th>
                <th>Erstellt am</th>
                <th>Aktionen</th>
              </tr>
            </thead>
            <tbody>
              <% templates.forEach(tpl => { %>
              <%
                let ids = [];
                try { ids = typeof tpl.training_ids === 'string' ? JSON.parse(tpl.training_ids) : tpl.training_ids; } catch(e) {}
              %>
              <tr>
                <td style="font-weight:500;"><%= tpl.name %></td>
                <td class="td-muted"><%= tpl.description || '–' %></td>
                <td>
                  <span class="badge" style="background:var(--primary-light,#fef2f2);color:var(--primary,#dc2626);font-weight:600;">
                    <%= ids.length %> Unterweisung(en)
                  </span>
                </td>
                <td class="td-muted"><%= new Date(tpl.created_at).toLocaleDateString('de-DE') %></td>
                <td>
                  <div class="action-group">
                    <a href="/admin/assignment-templates/<%= tpl.id %>/edit" class="btn btn-sm btn-secondary" title="Bearbeiten">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </a>
                    <form method="POST" action="/admin/assignment-templates/<%= tpl.id %>/delete" style="display:inline;">
                      <button type="submit" class="btn btn-sm btn-ghost" title="Löschen"
                              data-confirm="Vorlage &quot;<%= tpl.name %>&quot; wirklich löschen?"
                              style="color:var(--danger);">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
