<!DOCTYPE html>
<html lang="de">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/admin-sidebar', { activePage: 'reminders' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Erinnerungen', adminView: true }) %>
    <div class="page-content">

      <div class="page-header">
        <div class="page-header-title">
          <h1>E-Mail-Erinnerungen</h1>
          <p>Automatische Erinnerungen werden 7 Tage vor Fälligkeit versendet.</p>
        </div>
      </div>

      <div class="alert alert-info" style="margin-bottom:20px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Das System prüft stündlich auf fällige Erinnerungen und sendet automatisch E-Mails an Mitarbeiter, deren Unterweisung in 7 Tagen fällig ist.
      </div>

      <div class="card">
        <% if (reminders.length === 0) { %>
          <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="display:block;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            <h3>Noch keine Erinnerungen versendet</h3>
            <p>Erinnerungen werden automatisch 7 Tage vor Fälligkeit verschickt.</p>
          </div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Mitarbeiter</th>
                <th>E-Mail</th>
                <th>Unterweisung</th>
                <th>Typ</th>
                <th>Gesendet am</th>
              </tr>
            </thead>
            <tbody>
              <% reminders.forEach(r => { %>
              <tr>
                <td style="font-weight:500;"><%= r.user_name %></td>
                <td class="td-muted"><%= r.user_email %></td>
                <td class="td-muted"><%= r.training_title %></td>
                <td>
                  <span class="tag">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:12px;height:12px;"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    <%= r.type === '7days' ? '7 Tage' : r.type %>
                  </span>
                </td>
                <td class="td-muted">
                  <%= new Date(r.sent_at).toLocaleString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
