<!DOCTYPE html>
<html lang="de">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/admin-sidebar', { activePage: 'users' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: user_edit ? 'Mitarbeiter bearbeiten' : 'Neuer Mitarbeiter', adminView: true }) %>
    <div class="page-content">

      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

      <div style="max-width:600px;margin:0 auto;">
        <div class="d-flex align-center gap-12 mb-24">
          <a href="/admin/users" class="btn btn-sm btn-secondary">← Zurück</a>
          <h2 style="font-size:18px;font-weight:600;"><%= user_edit ? 'Mitarbeiter bearbeiten' : 'Neuen Mitarbeiter anlegen' %></h2>
        </div>

        <div class="card">
          <div class="card-body">
            <form method="POST" action="<%= user_edit ? '/admin/users/'+user_edit.id : '/admin/users' %>">
              <% if (user_edit) { %><input type="hidden" name="_method" value="PUT"><% } %>

              <div class="form-group">
                <label class="form-label">Vollständiger Name <span class="required">*</span></label>
                <input type="text" name="name" class="form-control" required
                       value="<%= user_edit ? user_edit.name : '' %>" placeholder="Vor- und Nachname">
              </div>

              <div class="form-group">
                <label class="form-label">E-Mail-Adresse <span class="required">*</span></label>
                <input type="email" name="email" class="form-control" required
                       value="<%= user_edit ? user_edit.email : '' %>" placeholder="name@unternehmen.de">
              </div>

              <div class="form-group">
                <label class="form-label">
                  Passwort <% if (user_edit) { %><span style="font-weight:400;color:var(--text-secondary);">(leer lassen = nicht ändern)</span><% } else { %><span class="required">*</span><% } %>
                </label>
                <input type="password" name="password" class="form-control"
                       placeholder="<%= user_edit ? 'Neues Passwort (optional)' : 'Passwort' %>"
                       <%= !user_edit ? 'required' : '' %> autocomplete="new-password">
                <div class="form-hint">Mindestens 6 Zeichen.</div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Abteilung</label>
                  <input type="text" name="abteilung" class="form-control"
                         value="<%= user_edit ? (user_edit.abteilung || '') : '' %>" placeholder="z.B. Produktion">
                </div>
                <div class="form-group">
                  <label class="form-label">Position</label>
                  <input type="text" name="position" class="form-control"
                         value="<%= user_edit ? (user_edit.position || '') : '' %>" placeholder="z.B. Lagerleiter">
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Geburtsdatum</label>
                <input type="date" name="geburtsdatum" class="form-control"
                       value="<%= user_edit && user_edit.geburtsdatum ? new Date(user_edit.geburtsdatum).toISOString().split('T')[0] : '' %>">
              </div>

              <div class="form-group">
                <label class="form-label">Firma</label>
                <input type="text" name="firma" class="form-control"
                       value="<%= user_edit ? (user_edit.firma || '') : '' %>" placeholder="z.B. Mustermann GmbH">
              </div>

              <div class="form-group">
                <label class="form-label">Firma Anschrift</label>
                <textarea name="firma_anschrift" class="form-control" rows="3"
                          placeholder="Straße, PLZ Ort"><%= user_edit ? (user_edit.firma_anschrift || '') : '' %></textarea>
              </div>

              <div class="form-group">
                <label class="form-label">Rolle <span class="required">*</span></label>
                <select name="role" class="form-control">
                  <option value="mitarbeiter" <%= !user_edit || user_edit.role==='mitarbeiter' ? 'selected' : '' %>>Mitarbeiter</option>
                  <option value="admin"       <%= user_edit && user_edit.role==='admin'        ? 'selected' : '' %>>Administrator</option>
                </select>
              </div>

              <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:8px;">
                <a href="/admin/users" class="btn btn-secondary">Abbrechen</a>
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <%= user_edit ? 'Speichern' : 'Mitarbeiter anlegen' %>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
