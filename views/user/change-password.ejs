<!DOCTYPE html>
<html lang="de">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <% if (user && user.role === 'admin') { %>
    <%- include('../partials/admin-sidebar', { activePage: '' }) %>
  <% } else { %>
    <%- include('../partials/sidebar', { activePage: '' }) %>
  <% } %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Passwort ändern', adminView: user && user.role === 'admin' }) %>
    <div class="page-content">

      <div style="max-width:460px;margin:0 auto;">

        <% if (success) { %>
          <div class="alert alert-success" style="margin-bottom:20px;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <%= success %>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error" style="margin-bottom:20px;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
            <%= error %>
          </div>
        <% } %>

        <div class="card">
          <div class="card-header">
            <span class="card-title">Passwort ändern</span>
          </div>
          <div class="card-body">
            <p style="font-size:14px;color:var(--text-secondary);margin-bottom:20px;">
              Wählen Sie ein sicheres Passwort mit mindestens 8 Zeichen.
            </p>
            <form method="POST" action="/change-password">
              <div class="form-group">
                <label class="form-label" for="current_password">Aktuelles Passwort <span class="required">*</span></label>
                <input type="password" id="current_password" name="current_password"
                       class="form-control" required autocomplete="current-password"
                       placeholder="Ihr aktuelles Passwort">
              </div>
              <div class="form-group">
                <label class="form-label" for="new_password">Neues Passwort <span class="required">*</span></label>
                <input type="password" id="new_password" name="new_password"
                       class="form-control" required autocomplete="new-password"
                       placeholder="Mindestens 8 Zeichen" minlength="8">
              </div>
              <div class="form-group">
                <label class="form-label" for="confirm_password">Neues Passwort wiederholen <span class="required">*</span></label>
                <input type="password" id="confirm_password" name="confirm_password"
                       class="form-control" required autocomplete="new-password"
                       placeholder="Passwort bestätigen" minlength="8">
              </div>
              <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:8px;">
                <a href="<%= user && user.role === 'admin' ? '/admin/dashboard' : '/dashboard' %>" class="btn btn-secondary">
                  Abbrechen
                </a>
                <button type="submit" class="btn btn-primary">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Passwort speichern
                </button>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
