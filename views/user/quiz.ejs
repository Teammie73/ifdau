<!DOCTYPE html>
<html lang="de">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'trainings' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Lernerfolgskontrolle', adminView: false }) %>
    <div class="page-content">

      <div class="quiz-container">
        <!-- Header -->
        <div class="d-flex align-center gap-12 mb-16" style="flex-wrap:wrap;">
          <a href="/trainings/<%= assignment.id %>/read" class="btn btn-sm btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Zurück
          </a>
          <span style="font-size:15px;font-weight:600;"><%= assignment.title %></span>
        </div>

        <div class="alert alert-info" style="margin-bottom:16px;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Bestehensgrenze: <strong><%= assignment.passing_score %> %</strong>
        </div>

        <!-- Progress -->
        <div class="quiz-progress-text" id="quizProgressText">Frage 1 von ...</div>
        <div class="progress-bar-wrap">
          <div class="progress-bar-fill" id="quizProgressFill" style="width:0%"></div>
        </div>

        <!-- Quiz area -->
        <div id="quizContainer"></div>

        <!-- Navigation -->
        <div class="quiz-nav">
          <button class="btn btn-secondary" id="btnPrev" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Zurück
          </button>
          <div style="display:flex;gap:10px;">
            <button class="btn btn-primary" id="btnNext">
              Weiter
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </button>
            <button class="btn btn-success" id="btnSubmit" style="display:none;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Abgeben
            </button>
          </div>
        </div>

        <!-- Submit form -->
        <form method="POST" action="/trainings/<%= assignment.id %>/quiz/submit" id="quizForm" style="display:none;">
          <input type="hidden" name="answers" id="answersInput">
        </form>
      </div>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>
<script>
window.QUIZ_DATA = {
  questions: <%- questions %>,
  passingScore: <%= passingScore %>,
  assignmentId: <%= assignment.id %>
};
</script>
</body>
</html>
