<!DOCTYPE html>
<html lang="de">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'certificates' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Meine Zertifikate', adminView: false }) %>
    <div class="page-content">

      <!-- ── Gesamtzertifikat Banner ────────────────────────── -->
      <div class="card" style="margin-bottom:24px;border:2px solid <%= allPassed ? 'var(--success)' : 'var(--border)' %>;">
        <div class="card-body" style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 24px;flex-wrap:wrap;">
          <div style="display:flex;align-items:center;gap:14px;">
            <div style="width:48px;height:48px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;
                        background:<%= allPassed ? 'var(--success-bg)' : 'var(--bg)' %>;
                        color:<%= allPassed ? 'var(--success)' : 'var(--text-secondary)' %>;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:24px;height:24px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
              </svg>
            </div>
            <div>
              <div style="font-weight:700;font-size:1rem;margin-bottom:3px;">
                Gesamtzertifikat / Final Certificate
              </div>
              <div style="font-size:0.875rem;color:var(--text-secondary);">
                <% if (allPassed) { %>
                  Alle Unterweisungen bestanden – Ihr persönliches Gesamtzertifikat ist bereit.
                <% } else if (totalAssignments === 0) { %>
                  Noch keine Unterweisungen zugewiesen.
                <% } else { %>
                  Verfügbar sobald alle <%= totalAssignments %> Unterweisung(en) bestanden wurden.
                <% } %>
              </div>
            </div>
          </div>
          <% if (allPassed) { %>
            <a href="/certificate/final"
               class="btn btn-primary"
               style="display:inline-flex;align-items:center;gap:8px;flex-shrink:0;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:17px;height:17px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Gesamtzertifikat herunterladen (PDF)
            </a>
          <% } else { %>
            <button class="btn btn-primary"
                    disabled
                    style="display:inline-flex;align-items:center;gap:8px;flex-shrink:0;opacity:0.45;cursor:not-allowed;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:17px;height:17px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Gesamtzertifikat herunterladen (PDF)
            </button>
          <% } %>
        </div>
      </div>

      <% if (certificates.length === 0) { %>
        <div class="card">
          <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="display:block;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
            <h3>Noch keine Zertifikate</h3>
            <p>Schließen Sie eine Unterweisung erfolgreich ab, um ein Zertifikat zu erhalten.</p>
          </div>
        </div>
      <% } else { %>
        <% certificates.forEach(cert => { %>
        <div class="cert-card">
          <div style="display:flex;align-items:center;gap:14px;flex:1;min-width:0;">
            <div style="width:48px;height:48px;border-radius:12px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:24px;height:24px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <div class="cert-info">
              <div class="cert-title"><%= cert.training_title %></div>
              <div class="cert-meta">
                <%= cert.category_name || 'Keine Kategorie' %>
                &nbsp;·&nbsp; Ergebnis: <strong><%= Math.round(cert.score) %> %</strong>
                &nbsp;·&nbsp; Ausgestellt: <%= new Date(cert.issued_at).toLocaleDateString('de-DE', {day:'2-digit',month:'long',year:'numeric'}) %>
              </div>
            </div>
          </div>
          <div style="flex-shrink:0;">
            <span style="font-size:11px;color:var(--text-secondary);display:block;text-align:right;margin-bottom:4px;">
              Nr. IFDAU-<%= String(cert.id).padStart(6,'0') %>
            </span>
            <% if (cert.pdf_path) { %>
              <a href="/certificates/<%= cert.id %>/download" class="btn btn-sm btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                PDF
              </a>
            <% } else { %>
              <span class="badge badge-archived">Kein PDF</span>
            <% } %>
          </div>
        </div>
        <% }) %>
      <% } %>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
