<!DOCTYPE html>
<html lang="de">
<head>
  <%- include('../partials/head') %>
  <style>
    /* ── Passed: hero banner ─────────────────────────── */
    .result-hero {
      text-align: center;
      padding: 48px 36px 36px;
    }
    .result-trophy {
      width: 80px; height: 80px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    .result-trophy.passed { background: #dcfce7; }
    .result-trophy.failed { background: #fee2e2; }
    .result-trophy svg    { width: 40px; height: 40px; }

    .result-score-ring {
      display: inline-flex;
      align-items: baseline;
      gap: 4px;
      margin-bottom: 16px;
    }
    .result-score-ring .score-num {
      font-size: 64px;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -2px;
    }
    .result-score-ring .score-unit {
      font-size: 28px;
      font-weight: 700;
      opacity: .7;
    }
    .score-passed { color: #16a34a; }
    .score-failed { color: #dc2626; }

    .result-title {
      font-size: 26px;
      font-weight: 800;
      margin-bottom: 8px;
    }
    .result-subtitle {
      font-size: 15px;
      color: var(--text-secondary, #64748b);
      max-width: 420px;
      margin: 0 auto 28px;
      line-height: 1.6;
    }

    /* ── Details grid ────────────────────────────────── */
    .result-details {
      background: var(--bg-secondary, #f8fafc);
      border-radius: 10px;
      padding: 20px 24px;
      text-align: left;
      margin: 0 36px 28px;
    }
    .result-details-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px 24px;
    }
    .result-detail-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-secondary, #64748b);
      text-transform: uppercase;
      letter-spacing: .04em;
      margin-bottom: 3px;
    }
    .result-detail-value {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary, #0f172a);
    }

    /* ── Actions ─────────────────────────────────────── */
    .result-actions {
      padding: 0 36px 40px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .btn-full { width: 100%; justify-content: center; }
    .btn-xl {
      padding: 14px 24px;
      font-size: 16px;
    }
  </style>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'trainings' }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { pageTitle: result.passed ? 'Bestanden!' : 'Nicht bestanden', adminView: false }) %>
    <div class="page-content">

      <div style="max-width:560px;margin:0 auto;">
        <div class="card" style="overflow:hidden;">

          <!-- ── HERO ─────────────────────────────────────── -->
          <div class="result-hero" style="border-bottom:1.5px solid var(--border,#e2e8f0);">

            <div class="result-trophy <%= result.passed ? 'passed' : 'failed' %>">
              <% if (result.passed) { %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="#16a34a"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/></svg>
              <% } else { %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="#dc2626"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
              <% } %>
            </div>

            <div class="result-score-ring">
              <span class="score-num <%= result.passed ? 'score-passed' : 'score-failed' %>">
                <%= Math.round(result.score) %>
              </span>
              <span class="score-unit <%= result.passed ? 'score-passed' : 'score-failed' %>">%</span>
            </div>

            <% if (result.passed) { %>
              <div class="result-title" style="color:#16a34a;">Herzlichen Glückwunsch!</div>
              <p class="result-subtitle">
                Sie haben die Unterweisung <strong><%= result.title %></strong> erfolgreich bestanden.
              </p>
            <% } else { %>
              <div class="result-title" style="color:#dc2626;">Nicht bestanden</div>
              <p class="result-subtitle">
                Die Mindestpunktzahl von <strong><%= result.passing_score %> %</strong> wurde nicht erreicht.
                Lesen Sie den Lerninhalt erneut durch und versuchen Sie es nochmals.
              </p>
            <% } %>

          </div>

          <!-- ── DETAILS ───────────────────────────────────── -->
          <div class="result-details">
            <div class="result-details-grid">
              <div>
                <div class="result-detail-label">Unterweisung</div>
                <div class="result-detail-value"><%= result.title %></div>
              </div>
              <div>
                <div class="result-detail-label">Ihr Ergebnis</div>
                <div class="result-detail-value" style="color:<%= result.passed ? '#16a34a' : '#dc2626' %>">
                  <%= Math.round(result.score) %> %
                </div>
              </div>
              <div>
                <div class="result-detail-label">Bestehensgrenze</div>
                <div class="result-detail-value"><%= result.passing_score %> %</div>
              </div>
              <div>
                <div class="result-detail-label">Abgeschlossen am</div>
                <div class="result-detail-value">
                  <%= new Date(result.completed_at || Date.now()).toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric'}) %>
                </div>
              </div>
            </div>
          </div>

          <!-- ── ACTIONS ───────────────────────────────────── -->
          <div class="result-actions">

            <% if (result.passed) { %>
              <!-- ── BESTANDEN: Zertifikat Download prominent ── -->
              <% if (result.cert_id && result.pdf_path) { %>
                <a href="/certificates/<%= result.cert_id %>/download"
                   class="btn btn-primary btn-full btn-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:20px;height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  Zertifikat herunterladen (PDF)
                </a>
              <% } else { %>
                <a href="/certificates" class="btn btn-primary btn-full btn-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:20px;height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                  Meine Zertifikate
                </a>
              <% } %>
              <a href="/my-trainings" class="btn btn-secondary btn-full">
                Zu meinen Unterweisungen
              </a>

            <% } else { %>
              <!-- ── NICHT BESTANDEN: Retry prominent ────────── -->
              <a href="/trainings/<%= result.assignment_id %>/read"
                 class="btn btn-primary btn-full btn-xl">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:20px;height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
                Unterweisung wiederholen
              </a>
              <a href="/my-trainings" class="btn btn-secondary btn-full">
                Zu meinen Unterweisungen
              </a>

            <% } %>

          </div>

        </div>
      </div>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>

<% if (result.passed) { %>
<script>
/* ── Konfetti-Animation ──────────────────────────────── */
(function () {
  var canvas = document.createElement('canvas');
  canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
  document.body.appendChild(canvas);
  var ctx = canvas.getContext('2d');

  function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
  resize();
  window.addEventListener('resize', resize);

  var COLORS = ['#dc2626','#16a34a','#2563eb','#d97706','#7c3aed','#db2777','#0891b2','#059669'];
  var pieces = [];

  for (var i = 0; i < 180; i++) {
    pieces.push({
      x:  Math.random() * canvas.width,
      y:  Math.random() * canvas.height * 0.6 - canvas.height * 0.6,
      w:  Math.random() * 11 + 6,
      h:  Math.random() * 6  + 4,
      r:  Math.random() * 360,
      rs: (Math.random() - 0.5) * 8,
      vx: (Math.random() - 0.5) * 2.5,
      vy: Math.random() * 3.5 + 2,
      color: COLORS[Math.floor(Math.random() * COLORS.length)],
      shape: Math.random() > 0.5 ? 'rect' : 'circle'
    });
  }

  var start = Date.now();

  function frame() {
    var elapsed = Date.now() - start;
    if (elapsed > 5000) { canvas.remove(); return; }

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var alpha = elapsed > 3500 ? 1 - (elapsed - 3500) / 1500 : 1;
    ctx.globalAlpha = Math.max(0, alpha);

    pieces.forEach(function (p) {
      p.y  += p.vy;
      p.x  += p.vx;
      p.r  += p.rs;
      if (p.y > canvas.height + 20) { p.y = -20; p.x = Math.random() * canvas.width; }

      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.r * Math.PI / 180);
      ctx.fillStyle = p.color;
      if (p.shape === 'circle') {
        ctx.beginPath();
        ctx.arc(0, 0, p.w / 2, 0, Math.PI * 2);
        ctx.fill();
      } else {
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
      }
      ctx.restore();
    });

    requestAnimationFrame(frame);
  }

  frame();
})();
</script>
<% } %>
</body>
</html>
